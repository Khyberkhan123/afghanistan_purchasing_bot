# ─────────────────────────────────────────────────────────────
#  Telegram Bot Configuration
# ─────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_from_botfather
BOT_USERNAME=your_bot_username
WEBHOOK_URL=https://yourdomain.com/webhook
WEBHOOK_SECRET=your_webhook_secret

# ─────────────────────────────────────────────────────────────
#  Admin Configuration
# ─────────────────────────────────────────────────────────────
ADMIN_IDS=123456789,987654321
ADMIN_USERNAME=admin_username

# ─────────────────────────────────────────────────────────────
#  Database
# ─────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/bot.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/afghanistan_purchasing

# ─────────────────────────────────────────────────────────────
#  Exchange Rate API (free tier available)
# ─────────────────────────────────────────────────────────────
EXCHANGE_RATE_API_KEY=your_api_key
# Fallback manual rate if API fails
FALLBACK_CNY_TO_AFN=9.8

# ─────────────────────────────────────────────────────────────
#  Shipping Configuration
# ─────────────────────────────────────────────────────────────
# Base shipping cost per kg (CNY)
SHIPPING_AIR_BASE=80
SHIPPING_SEA_BASE=25
SHIPPING_LAND_BASE=35

# Delivery time estimates (days)
DELIVERY_AIR_DAYS=7
DELIVERY_SEA_DAYS=45
DELIVERY_LAND_DAYS=20

# ─────────────────────────────────────────────────────────────
#  Business Settings
# ─────────────────────────────────────────────────────────────
COMPANY_NAME=Afghanistan Purchasing Agent
OFFICE_ADDRESS=Kabul, Afghanistan - Main Bazaar Street
OFFICE_PHONE=+93-XXX-XXXX-XXX
BUSINESS_HOURS=Saturday-Thursday 8:00-17:00

# Service Fees
SERVICE_FEE_PERCENT=5
PHOTO_INSPECTION_FEE=15

# ─────────────────────────────────────────────────────────────
#  Referral System
# ─────────────────────────────────────────────────────────────
REFERRAL_REWARD_AFN=500
REFERRAL_MIN_ORDER_AFN=2000

# ─────────────────────────────────────────────────────────────
#  Logging
# ─────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log

# ─────────────────────────────────────────────────────────────
#  Environment
# ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=false
